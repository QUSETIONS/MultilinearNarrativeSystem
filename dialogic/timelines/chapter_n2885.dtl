set {mysterious_man} = ""
set {small_dark_man} = ""
set {scarlet_robe} = ""
set {button_evidence} = ""
set {passport_oil_stain} = ""
set {pipe_cleaner} = ""
set {watch_time} = ""
set {countess_identity} = ""
set {princess_confession} = ""
