[gd_scene format=3]

[node name="SaveSlot" type="PanelContainer"]
size_flags_horizontal = 3

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 8

[node name="HBoxContainer" type="HBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Thumbnail" type="TextureRect" parent="MarginContainer/HBoxContainer"]
custom_minimum_size = Vector2(96, 54)
layout_mode = 2
expand_mode = 1
stretch_mode = 5

[node name="Meta" type="VBoxContainer" parent="MarginContainer/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3

[node name="SlotLabel" type="Label" parent="MarginContainer/HBoxContainer/Meta"]
layout_mode = 2
text = "存档 1"

[node name="TimestampLabel" type="Label" parent="MarginContainer/HBoxContainer/Meta"]
layout_mode = 2
text = "--"

[node name="ChapterLabel" type="Label" parent="MarginContainer/HBoxContainer/Meta"]
layout_mode = 2
text = "空槽位"

[node name="ActionButton" type="Button" parent="MarginContainer/HBoxContainer"]
custom_minimum_size = Vector2(96, 0)
layout_mode = 2
text = "保存"
